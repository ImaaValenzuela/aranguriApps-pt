root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.{kt,kts}]
# Kotlin specific rules
max_line_length = 120
ktlint_function_naming_ignore_when_annotated_with = Composable


[**/generated/**/*]
ktlint = disabled
ktlint_standard = disabled

[**/build/**/*]
ktlint = disabled
ktlint_standard = disabled
